# ─── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/roverse

# Roblox OAuth 2.0 credentials
# Create your app at: https://create.roblox.com/dashboard/credentials
ROBLOX_CLIENT_ID=your_roblox_client_id
ROBLOX_CLIENT_SECRET=your_roblox_client_secret

# Session secret — use a long random string (min 32 chars)
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
SESSION_SECRET=change_me_to_a_random_secret

# ─── Optional (defaults shown) ───────────────────────────────────────────────

# API server port
PORT=8080

# Base path for the frontend (keep "/" for local dev)
BASE_PATH=/
