# ─── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Docker Compose (local): postgresql://rocheck:rocheck123@localhost:5432/rocheck
# External host: postgresql://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_URL=postgresql://rocheck:rocheck123@localhost:5432/rocheck

# ─── Roblox OAuth2 ─────────────────────────────────────────────────────────────
# 1. Go to https://create.roblox.com/dashboard/credentials
# 2. Create a new OAuth2 application
# 3. Set redirect URI to: http://localhost:5000/api/auth/roblox/callback
# 4. Copy the Client ID and Secret below
ROBLOX_CLIENT_ID=your_roblox_client_id
ROBLOX_CLIENT_SECRET=your_roblox_client_secret

# Redirect URI — change to your domain in production
ROBLOX_REDIRECT_URI=http://localhost:5000/api/auth/roblox/callback

# ─── Session Secret ────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
SESSION_SECRET=change_me_to_a_long_random_secret
